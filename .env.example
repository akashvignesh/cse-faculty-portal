# ── Faculty Portal server configuration ──────────────────────────────────────
# Copy to .env.local (gitignored) and fill in the database credentials.

# local = bundled mock data, fully offline (default)
# db    = university MySQL through the SSH tunnel
FACULTY_DATA_MODE=local

# MySQL connection (only required when FACULTY_DATA_MODE=db).
# Open the tunnel first:  ssh -L 3307:oceanus:3306 <user>@cerf.cse.buffalo.edu
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=
DB_PASSWORD=
DB_DATABASE=ubs_emp

# Userid stamped into cfp_* editor/audit columns until real auth lands.
DEV_USERID=system
